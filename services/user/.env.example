# ============================================================
# User Service — Environment Variables
# ============================================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit .env ke repository!
# ============================================================

APP_PORT=8082

# Database MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=secretpassword
MYSQL_DATABASE=user_db

# SECURITY: Pastikan sama dengan auth service (min 32 char)
JWT_SECRET=rahasia-negara-paling-aman-yang-sangat-panjang-sekali

# RabbitMQ
RABBITMQ_URL=amqp://rmqadmin:rmqpassword@rabbitmq:5672/

# MinIO Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=users
# URL publik agar bisa diakses oleh frontend/klien (misal: https://cdn.domain.com)
MINIO_PUBLIC_URL=http://localhost:9000

# CORS — domain frontend / gateway yang diizinkan
CORS_ALLOW_ORIGINS=http://localhost:8080

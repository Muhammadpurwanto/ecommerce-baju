# ============================================================
# Product Service — Environment Variables
# ============================================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit .env ke repository!
# ============================================================

APP_PORT=8083

# Database MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=product_db

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO Object Storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=products
# URL publik agar bisa diakses oleh frontend/klien (misal: https://cdn.domain.com)
MINIO_PUBLIC_URL=http://localhost:9000

# CORS — domain frontend / gateway yang diizinkan
CORS_ALLOW_ORIGINS=http://localhost:8080

# ============================================================
# Notification Service — Environment Variables
# ============================================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit .env ke repository!
# ============================================================

APP_PORT=8087

# SMTP Email Configuration
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=my_mailtrap_user
SMTP_PASSWORD=my_mailtrap_pass
SENDER_NAME=Ecommerce Baju API

# Message Broker (RabbitMQ)
RABBITMQ_URL=amqp://rmqadmin:rmqpassword@localhost:5672/

# CORS — domain frontend / gateway yang diizinkan
CORS_ALLOW_ORIGINS=http://localhost:8080

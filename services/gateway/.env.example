# ============================================================
# Gateway Service — Environment Variables
# ============================================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit .env ke repository!
# ============================================================

APP_PORT=8080

JWT_SECRET=rahasia-negara-paling-aman-yang-sangat-panjang-sekali

# gRPC Service URLs (Docker Compose)
AUTH_SERVICE_URL=auth-service:50051
USER_SERVICE_URL=user-service:50052
PRODUCT_SERVICE_URL=product-service:50053
CART_SERVICE_URL=cart-service:50054
ORDER_SERVICE_URL=order-service:50055
PAYMENT_SERVICE_URL=payment-service:50056

# HTTP Service URLs (untuk proxy OAuth & Image upload)
AUTH_SERVICE_HTTP_URL=http://auth-service:8081
PRODUCT_SERVICE_HTTP_URL=http://product-service:8083

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_EXPIRATION=60

# CORS — domain frontend yang diizinkan (pisah dengan koma)
CORS_ALLOW_ORIGINS=https://your-domain.com

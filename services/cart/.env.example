# ============================================================
# Cart Service — Environment Variables
# ============================================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit .env ke repository!
# ============================================================

APP_PORT=8084

# Database MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cart_db

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS — domain frontend / gateway yang diizinkan
CORS_ALLOW_ORIGINS=http://localhost:8080

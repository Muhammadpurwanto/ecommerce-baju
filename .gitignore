# =========================================================================
# Ecommerce Baju - Root .gitignore
# =========================================================================

# Dependencies and Package Manager
**/node_modules/
**/.pnp
.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# Next.js Build and Output
**/.next/
**/out/
**/build/
**/dist/
**/*.tsbuildinfo
**/next-env.d.ts

# Go Binaries and Executables
**/main
**/main.exe
**/*.exe
**/*.exe~
**/*.dll
**/*.so
**/*.dylib
**/tmp_*
**/tmp/
**/bin/

# Environment and Secrets (CRITICAL)
# Ignore all .env files but allow committing .env.example files
**/.env*
!**/.env.example

# Debug and Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*
**/*.log

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.user

# Operating System Files
**/.DS_Store
**/Thumbs.db
ehthumbs.db
Desktop.ini

# Archives and Redundant Folders
services.zip
github.com/

# Local VM SSH Key & Setup Guides
id_ed25519
vps_setup_guide.md
